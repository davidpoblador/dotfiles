{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash

# Don't quarantine cask apps — avoids the "downloaded from internet" warning
export HOMEBREW_CASK_OPTS="--no-quarantine"

brew bundle --file=/dev/stdin << EOF
tap "buo/cask-upgrade"

# Homebrew, Terminal and Shell Tools
brew "chezmoi"
brew "mas"
brew "tmux"
brew "zsh-completions"
brew "zsh-syntax-highlighting"

# System Tools
brew "curl"
brew "d2"
brew "duckdb"
brew "ffmpeg"
brew "fileicon"
brew "fx"
brew "imagemagick"
brew "jless"
brew "jq"
brew "jnv"
brew "knock"
brew "litecli"
brew "mosh"
brew "qrencode"
brew "rsync"
brew "sc-im"
brew "shfmt"
brew "silicon"
brew "tokei"
brew "tree"
brew "watchexec"
brew "yq"
brew "wget"
cask "ngrok"

# Stack
brew "cmake"
brew "coreutils"
brew "create-dmg"
brew "protobuf"
brew "sentencepiece"

# AI Stuff
brew "agent-browser"
brew "ollama"
cask "macwhisper"

# git stuff
brew "git"
brew "git-absorb"
brew "tig"

# programming languages

# modern replacements
brew "broot"
brew "cheat"
brew "curlie"
brew "duff"
brew "gping"
brew "httpie"
brew "procs"
brew "the_silver_searcher"
brew "tlrc"

# fonts
cask "font-jetbrains-mono-nerd-font"

# notes / knowledge base
cask "obsidian"

# password manager
cask "bitwarden"

# cloud stuff
cask "gcloud-cli"

# docker
cask "docker-desktop"
brew "docker-completion"

# AppStore stuff
mas "DaisyDisk", id: 411643860
mas "Obsidian Web Clipper", id: 6720708363
mas "Keynote", id: 409183694
mas "Numbers", id: 409203825
mas "Pages", id: 409201541
mas "Slack", id: 803453959
mas "Xcode", id: 497799835

EOF
{{ end -}}
