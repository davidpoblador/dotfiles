{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# Set up wallpaper sync folder and apply wallpapers to attached displays.

WALLPAPERS_DIR="$HOME/sync/exchange/wallpapers"

# Ensure the synced directory exists (creates it locally; syncthing picks it up)
mkdir -p "$WALLPAPERS_DIR"

# Symlink ~/Pictures/wallpapers for easy GUI access
if [[ ! -e "$HOME/Pictures/wallpapers" ]]; then
  ln -s "$WALLPAPERS_DIR" "$HOME/Pictures/wallpapers"
fi

# Apply wallpapers (idempotent; noops if sync dir is empty)
if command -v bun &>/dev/null && [[ -x "$HOME/.local/bin/wallpaper-sync" ]]; then
  "$HOME/.local/bin/wallpaper-sync" --apply || true
fi
{{ end -}}
