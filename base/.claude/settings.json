{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Skill(frontend-design:frontend-design)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(djlint:*)",
      "Bash(docker images:*)",
      "Bash(docker history:*)",
      "Bash(docker build:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(gh api:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue view:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git commit:*)",
      "Bash(git describe:*)",
      "Bash(git diff:*)",
      "Bash(git fetch:*)",
      "Bash(git log:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git show:*)",
      "Bash(git stash pop:*)",
      "Bash(git stash push:*)",
      "Bash(git status:*)",
      "Bash(git switch:*)",
      "Bash(git tag:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(just:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(msgattrib:*)",
      "Bash(msgfmt:*)",
      "Bash(nc:*)",
      "Bash(bun:*)",
      "Bash(python:*)",
      "Bash(readlink:*)",
      "Bash(rg:*)",
      "Bash(ruff:*)",
      "Bash(rumdl:*)",
      "Bash(sed:*)",
      "Bash(tail:*)",
      "Bash(time:*)",
      "Bash(tree:*)",
      "Bash(ty:*)",
      "Bash(unzip:*)",
      "Bash(uv:*)",
      "Bash(uvx uv-bump:*)",
      "mcp__claude-in-chrome__tabs_context_mcp",
      "mcp__ide__getDiagnostics",
      "mcp__mongodb__find",
      "mcp__mongodb__indexes",
      "mcp__mongodb__listCollections",
      "Read(~/Desktop/*.png)",
      "WebFetch(domain:beanie-odm.dev)",
      "WebFetch(domain:bun.com)",
      "WebFetch(domain:bun.sh)",
      "WebFetch(domain:click.palletsprojects.com)",
      "WebFetch(domain:copier.readthedocs.io)",
      "WebFetch(domain:daisyui.com)",
      "WebFetch(domain:developers.google.com)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:dev.mailjet.com)",
      "WebFetch(domain:djlint.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:docs.astral.sh)",
      "WebFetch(domain:docs.authlib.org)",
      "WebFetch(domain:docs.npmjs.com)",
      "WebFetch(domain:docs.pydantic.dev)",
      "WebFetch(domain:docs.pytest.org)",
      "WebFetch(domain:docs.renovatebot.com)",
      "WebFetch(domain:fastapi.tiangolo.com)",
      "WebFetch(domain:github.blog)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:granian.dev)",
      "WebFetch(domain:htmx.org)",
      "WebFetch(domain:issuetracker.google.com)",
      "WebFetch(domain:itsdangerous.palletsprojects.com)",
      "WebFetch(domain:just.systems)",
      "WebFetch(domain:llm.datasette.io)",
      "WebFetch(domain:python-httpx.org)",
      "WebFetch(domain:redis.io)",
      "WebFetch(domain:redis-py.readthedocs.io)",
      "WebFetch(domain:rich.readthedocs.io)",
      "WebFetch(domain:sqlalchemy.org)",
      "WebFetch(domain:sqlmodel.tiangolo.com)",
      "WebFetch(domain:starlette.io)",
      "WebFetch(domain:streaq.readthedocs.io)",
      "WebFetch(domain:support.google.com)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:taplo.tamasfe.dev)",
      "WebFetch(domain:typer.tiangolo.com)",
      "WebFetch(domain:umami.is)",
      "WebFetch(domain:vibetuner.alltuner.com)",
      "WebFetch(domain:localhost)",
      "WebSearch"
    ],
    "deny": [],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cwd-changed-osc7.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-setup.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/user-prompt-split.sh"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cwd-changed-osc7.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/cwd-changed-osc7.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-start-setup.sh"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-remove.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "astral@astral-sh": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "expo@claude-plugins-official": true,
    "ast-grep@ast-grep-marketplace": true,
    "cloudflare@cloudflare": true,
    "impeccable@impeccable": true,
    "resend@resend-skills": true,
    "stripe@stripe": true,
    "vacant@alltuner": true,
    "selfmail@alltuner": true,
    "fastapi@alltuner": true,
    "shadcn@alltuner": true,
    "remotion-best-practices@alltuner": true,
    "find-skills@alltuner": true
  },
  "extraKnownMarketplaces": {
    "astral-sh": {
      "source": {
        "source": "github",
        "repo": "astral-sh/claude-code-plugins"
      }
    },
    "alltuner": {
      "source": {
        "source": "github",
        "repo": "alltuner/skills"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    },
    "impeccable": {
      "source": {
        "source": "github",
        "repo": "pbakaus/impeccable"
      }
    },
    "resend-skills": {
      "source": {
        "source": "github",
        "repo": "resend/resend-skills"
      }
    },
    "stripe": {
      "source": {
        "source": "github",
        "repo": "stripe/ai"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "tap"
  },
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "model": "claude-fable-5[1m]"
}
