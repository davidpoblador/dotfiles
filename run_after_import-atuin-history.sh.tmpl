{{ if eq .profile "prod" -}}
#!/bin/bash
# Import existing bash history into atuin on first run.

STAMP="${XDG_CACHE_HOME:-$HOME/.cache}/atuin_history_imported"

if [ -f "$STAMP" ]; then
  exit 0
fi

ATUIN="$(command -v atuin 2>/dev/null)"
if [ -z "$ATUIN" ] && [ -f "$HOME/.local/bin/mise" ]; then
  ATUIN="$("$HOME/.local/bin/mise" which atuin 2>/dev/null)"
fi

if [ -z "$ATUIN" ]; then
  exit 0
fi

if [ -f "$HOME/.bash_history" ]; then
  echo "[atuin] Importing bash history..."
  HISTFILE="$HOME/.bash_history" "$ATUIN" import auto
  touch "$STAMP"
  echo "[atuin] Import complete"
fi
{{ end -}}
