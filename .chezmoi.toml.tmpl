{{- $email := promptStringOnce . "email" "Email address" -}}
{{- $full_name := promptStringOnce . "full_name" "Full name" -}}
{{- $profile := promptStringOnce . "profile" "Profile (dev/prod, default: dev)" -}}

[data]
    email = {{ $email | quote }}
    full_name = {{ $full_name | quote }}
    profile = {{ if eq $profile "" }}"dev"{{ else }}{{ $profile | quote }}{{ end }}

