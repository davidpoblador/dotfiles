#!/bin/bash
# Setup environment: check prerequisites, install/update mise.

{{ if eq .chezmoi.os "linux" -}}
# Ensure zsh is installed and set as default shell
if ! command -v zsh &>/dev/null; then
  echo "ERROR: zsh is not installed. Run: sudo apt-get install -y zsh" >&2
  exit 1
fi

CURRENT_SHELL=$(getent passwd "$(whoami)" | cut -d: -f7)
if [[ "$(basename "$CURRENT_SHELL")" != "zsh" ]]; then
  echo "[setup] Setting zsh as default shell..."
  chsh -s "$(which zsh)"
  echo "[setup] Done. Log out and back in, then run chezmoi apply again."
  echo "[setup] If using SSH multiplexing, close the shared connection first: ssh -O exit <host>"
  exit 1
fi
{{ end -}}

# Install or update mise (user-space, no sudo)
MISE_BIN=""
if command -v mise &>/dev/null; then
  MISE_BIN="mise"
elif [ -f "$HOME/.local/bin/mise" ]; then
  MISE_BIN="$HOME/.local/bin/mise"
fi

if [ -n "$MISE_BIN" ]; then
  # Suppress the no-op "already up to date" message
  "$MISE_BIN" self-update -y 2>&1 | grep -vE "^mise is already up to date$" || true
else
  echo "[mise] Installing..."
  curl -fsSL https://mise.jdx.dev/install.sh | bash
fi
