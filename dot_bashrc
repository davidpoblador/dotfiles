# Production server .bashrc

# Non-interactive shells should not source this file
case $- in
    *i*) ;;
      *) return;;
esac

###########################################################
# Environment                                             #
###########################################################

export EDITOR="vim"
export VISUAL="vim"
export LANG="en_US.UTF-8"
export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

# Mise: use shims so all tools are immediately on PATH
[ -f "$HOME/.local/bin/mise" ] && eval "$("$HOME/.local/bin/mise" activate bash --shims)"

# Cargo
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

###########################################################
# History                                                 #
###########################################################

# Bash native history kept as fallback (atuin is the primary history tool)
HISTFILE="$HOME/.bash_history"
HISTSIZE=50000
HISTFILESIZE=50000
HISTCONTROL=ignoreboth
shopt -s histappend

###########################################################
# Tool Initialization (must come after history so         #
# starship can append to PROMPT_COMMAND)                  #
###########################################################

# Resolve real binary paths (avoids shim overhead on every keypress)
if [ -f "$HOME/.local/bin/mise" ]; then
  _starship="$("$HOME/.local/bin/mise" which starship 2>/dev/null)"
  _atuin="$("$HOME/.local/bin/mise" which atuin 2>/dev/null)"
else
  _starship="$(command -v starship 2>/dev/null)"
  _atuin="$(command -v atuin 2>/dev/null)"
fi

# Starship prompt (must init before atuin to avoid bash-preexec conflicts)
[ -n "$_starship" ] && eval "$("$_starship" init bash)"

# Atuin (shell history search via Ctrl-R)
[ -n "$_atuin" ] && eval "$("$_atuin" init bash)"

unset _starship _atuin

###########################################################
# Shell Options                                           #
###########################################################

shopt -s checkwinsize
shopt -s cdspell
shopt -s autocd 2>/dev/null

[ -x /usr/bin/lesspipe ] && eval "$(SHELL=/bin/sh lesspipe)"

###########################################################
# Colors                                                  #
###########################################################

if [ -x /usr/bin/dircolors ]; then
    test -r ~/.dircolors && eval "$(dircolors -b ~/.dircolors)" || eval "$(dircolors -b)"
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

###########################################################
# Aliases                                                 #
###########################################################

# Navigation
alias l='ls -la'
alias ll='ls -alF'
alias ..='cd ..'
alias ...='cd ../..'

# Git
alias ga='git add'
alias gc='git commit -m'
alias gps='git push'
alias gpl='git pull'
alias gs='git status'
alias gco='git checkout'
alias gb='git branch'

# Docker
alias dps='docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}"'
alias dcu='docker compose up -d'
alias dcd='docker compose down'
alias dcr='docker compose restart'
alias dcl='docker compose logs -f --tail 100'

# GitHub
alias ghw='gh repo view --web'
alias ghp='gh pr list --web'
alias ghpr='gh pr view --web'

# Claude Code
alias ccc='claude'
alias cccy='claude --dangerously-skip-permissions'

# System
alias ports='ss -tlnp'

###########################################################
# Functions                                               #
###########################################################

dlogs() { docker logs -f --tail 100 "$1"; }
dexec() { docker exec -it "$1" /bin/sh; }
rep() { cd ~/repos${1:+/$1}; }

###########################################################
# Completions                                             #
###########################################################

if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    . /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    . /etc/bash_completion
  fi
fi
