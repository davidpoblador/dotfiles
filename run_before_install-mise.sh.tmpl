{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Install or update mise on Linux (user-space, no sudo).

if [ -f "$HOME/.local/bin/mise" ]; then
  "$HOME/.local/bin/mise" self-update -y 2>/dev/null || true
else
  echo "[mise] Installing..."
  curl -fsSL https://mise.jdx.dev/install.sh | bash
fi
{{ end -}}
