{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
# Setup Linux environment: check prerequisites, install/update mise.

if ! command -v zsh &>/dev/null; then
  echo "ERROR: zsh is not installed. Run: sudo apt-get install -y zsh" >&2
  exit 1
fi

if [[ "$(basename "$SHELL")" != "zsh" ]]; then
  echo "ERROR: zsh is not your default shell. Run: chsh -s \$(which zsh)" >&2
  echo "Then log out and back in." >&2
  exit 1
fi

# Install or update mise (user-space, no sudo)
if [ -f "$HOME/.local/bin/mise" ]; then
  "$HOME/.local/bin/mise" self-update -y 2>/dev/null || true
else
  echo "[mise] Installing..."
  curl -fsSL https://mise.jdx.dev/install.sh | bash
fi
{{ end -}}
