"$schema" = 'https://starship.rs/config-schema.json'

# Performance tuning
scan_timeout = 30        # Milliseconds to scan for git repos
command_timeout = 500    # Max time for module commands
follow_symlinks = false  # Important for network filesystems

{{ if eq .profile "dev" -}}
format = """
[ŅéČ](color_orange)\
$os\
$username$hostname\
[Ņé░](bg:color_yellow fg:color_orange)\
$git_branch\
$git_status\
[Ņé░](fg:color_yellow bg:color_blue)\
$c\
$rust\
$golang\
$nodejs\
$php\
$java\
$kotlin\
$haskell\
$python\
[Ņé░](fg:color_blue bg:color_bg3)\
$docker_context\
[Ņé░](fg:color_bg3 bg:color_aqua)\
$directory\
[Ņé░](fg:color_aqua bg:color_bg1)\
$time\
[Ņé░](fg:color_bg1)\
$line_break\
$character"""

right_format = """${custom.project}"""
{{ else -}}
format = """
[ŅéČ](color_red)\
$os\
$hostname\
[Ņé░](bg:color_orange fg:color_red)\
