[username]
show_always = true
{{ if eq .profile "dev" -}}
style_user = "bg:color_orange fg:color_fg0"
style_root = "bg:color_orange fg:color_fg0"
format = '[ $user]($style)'
{{ else -}}
style_user = "bg:color_orange fg:color_fg0"
style_root = "bg:color_red fg:color_fg0 bold"
format = '[ $user ]($style)'
{{ end }}

[directory]
style = "bg:color_aqua"
format = '[[ $path ](bold fg:color_fg0 bg:color_aqua)]($style)'
{{ if eq .profile "dev" -}}
truncation_length = 1
{{ else -}}
truncation_length = 3
{{ end -}}
truncation_symbol = "ŌĆ”/"
truncate_to_repo = false

{{ if eq .profile "dev" -}}
[directory.substitutions]
"Documents" = "¾░łÖ "
"Downloads" = "’ĆÖ "
"Music" = "¾░ØÜ "
"Pictures" = "’ĆŠ "
"Developer" = "¾░▓ŗ "

[custom.project]
command = '''
common="$(git rev-parse --git-common-dir 2>/dev/null)"
repo="$(cd "$common/.." && basename "$PWD")"
toplevel="$(git rev-parse --show-toplevel)"
wt="$(basename "$toplevel")"
if [ "$repo" = "$wt" ]; then
  echo "$repo"
else
  echo "$repo:$wt"
fi
'''
when = 'git rev-parse --is-inside-work-tree 2>/dev/null'
style = "bg:color_purple"
format = '[ŅéČ](fg:color_purple)[[ ¾░ēŗ $output ](fg:color_fg0 bg:color_purple)]($style)[Ņé┤](fg:color_purple)'
shell = ["bash", "--noprofile", "--norc"]
{{ end -}}

[git_branch]
symbol = "’Éś"
style = "bg:color_yellow"
format = '[[ $symbol $branch ](fg:color_fg0 bg:color_yellow)]($style)'
truncation_length = 20
truncation_symbol = "ŌĆ”"
ignore_bare_repo = true

[git_status]
style = "bg:color_yellow"
format = '[[($all_status$ahead_behind )](fg:color_fg0 bg:color_yellow)]($style)'
untracked = "Ōł┐"

