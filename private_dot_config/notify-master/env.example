# Credentials for the notify-master Telegram notifier.
#
# Setup:
#   1. Create a bot via @BotFather on Telegram, copy the bot token.
#   2. Send any message to your new bot from your own account, then open
#      https://api.telegram.org/bot<TOKEN>/getUpdates in a browser. The
#      numeric "id" under "from" or "chat" is your chat id.
#   3. Copy this file to env in the same directory and fill in the values:
#        cp ~/.config/notify-master/env.example ~/.config/notify-master/env
#        chmod 600 ~/.config/notify-master/env
#        $EDITOR ~/.config/notify-master/env
#
# This file contains no secrets and is safe to commit. The real env file
# is not tracked by chezmoi.

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
