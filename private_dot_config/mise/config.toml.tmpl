[settings]
experimental = true
idiomatic_version_file_enable_tools = []

[[hooks.cd]]
script = """
if [ -f "uv.lock" ] && [ ! -d ".venv" ]; then
  echo "mise: uv.lock found without .venv, running uv sync..." >&2
  uv sync --frozen --quiet &
fi
if [ -f "bun.lock" ] && [ ! -d "node_modules" ]; then
  echo "mise: bun.lock found without node_modules, running bun install..." >&2
  bun install --frozen-lockfile &
fi
wait
"""

[tools]
atuin = "latest"
bat = "latest"
bottom = "latest"
bun = "latest"
delta = "latest"
difftastic = "latest"
fzf = "latest"
gh = "latest"
git-lfs = "latest"
go = "latest"
just = "latest"
lazygit = "latest"
lsd = "latest"
starship = "latest"
uv = "latest"
{{ if eq .profile "dev" -}}
awscli = "latest"
mc = "latest"
rust = "latest"
mongosh = "latest"
ty = "latest"
ruff = "latest"
prek = "latest"
actionlint = "latest"
"github:alltuner/mise-completions-sync" = "latest"
"go:golang.org/x/tools/gopls" = "latest"
rust-analyzer = "latest"
zig = "latest"
{{ end -}}
