[user]
    name = {{ .full_name | quote }}
    email = {{ .email | quote }}

[core]
{{ if eq .profile "dev" -}}
    pager = delta
{{ end -}}
    excludesfile = ~/.gitignore_global

{{ if eq .profile "dev" -}}
[interactive]
    diffFilter = delta --color-only --features=interactive

[delta]
    features = side-by-side line-numbers decorations Catppuccin-macchiato
    hyperlinks = true
    navigate = true

[delta "interactive"]
    keep-plus-minus-markers = false

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = "#067a00"
    hunk-header-style = file line-number syntax

[diff]
    tool = difftastic

[difftool]
    prompt = false

[difftool "difftastic"]
    cmd = difft "$LOCAL" "$REMOTE"

{{ end -}}
[init]
    defaultBranch = main

[push]
    autoSetupRemote = true

{{ if eq .profile "dev" -}}
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

{{ end -}}
[pager]
    log = less -FRX

{{ if eq .profile "dev" -}}
[include]
    path = macchiato.config

{{ end -}}
[alias]
    st = "!f(){ \
        if [ \"$(git rev-parse --is-bare-repository 2>/dev/null)\" = \"true\" ]; then \
            echo \"bare repo (no working tree). Try: git worktree list | git branch -vv | git log --oneline -n 20\"; \
            git worktree list 2>/dev/null || true; \
        else \
            git status \"$@\"; \
        fi; \
    }; f"
